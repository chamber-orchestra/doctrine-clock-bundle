{
  "name": "chamber-orchestra/doctrine-clock-bundle",
  "type": "symfony-bundle",
  "description": "Automatic Doctrine ORM timestamps using PHP attributes and Symfony Clock. Provides #[CreateTimestamp] and #[UpdateTimestamp] attributes with ready-to-use entity traits for createdDatetime/updatedDatetime fields.",
  "keywords": [
    "symfony",
    "doctrine",
    "timestamp",
    "created-at",
    "updated-at",
    "clock",
    "datepoint",
    "orm",
    "attributes",
    "auto-timestamp"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Andrew Lukin",
      "email": "lukin.andrej@gmail.com",
      "homepage": "https://github.com/wtorsi",
      "role": "Developer"
    }
  ],
  "require": {
    "ext-intl": "*",
    "php": "^8.5",
    "symfony/clock": "8.0.*",
    "chamber-orchestra/metadata-bundle": "8.0.*"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0",
    "symfony/test-pack": "^1.2",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94"
  },
  "autoload": {
    "psr-4": {
      "ChamberOrchestra\\DoctrineClockBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "8.0.*"
    }
  },
  "config": {
    "allow-plugins": {
      "symfony/runtime": true
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "analyse": "vendor/bin/phpstan analyse",
    "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
    "cs-fix": "vendor/bin/php-cs-fixer fix"
  }
}
